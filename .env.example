# Copy to .env and fill in values (never commit .env)
# On Netlify, add these keys in Site settings -> Environment variables.
# Preferred port. If busy, the server tries PORT+1 … up to PORT_BIND_ATTEMPTS times.
# If npm start still fails with EADDRINUSE, raise PORT (e.g. 4000) or PORT_BIND_ATTEMPTS.
PORT=3000
PORT_BIND_ATTEMPTS=10
APP_NAME=Subtitle Hub
TMDB_BEARER_TOKEN=
SUBDL_API_KEY=
OPENSUBTITLES_API_KEY=
OPENSUBTITLES_USERNAME=
OPENSUBTITLES_PASSWORD=
OPENSUBTITLES_USER_AGENT=SubtitleHub v1.0
