# Copy to .env and fill in values (never commit .env)
# On Netlify, add these keys in Site settings -> Environment variables.
# Preferred port. If busy, the server tries PORT+1 … up to PORT_BIND_ATTEMPTS times.
# If npm start still fails with EADDRINUSE, raise PORT (e.g. 4000) or PORT_BIND_ATTEMPTS.
PORT=3000
PORT_BIND_ATTEMPTS=10
APP_NAME=Subtitle Hub
TMDB_BEARER_TOKEN=
SUBDL_API_KEY=
OPENSUBTITLES_API_KEY=
OPENSUBTITLES_USERNAME=
OPENSUBTITLES_PASSWORD=
# Optional second account: when primary hits daily /download quota (or 429), retry with this user (fresh quota).
OPENSUBTITLES_USERNAME_FALLBACK=
OPENSUBTITLES_PASSWORD_FALLBACK=
# Optional; defaults to OPENSUBTITLES_API_KEY if unset (same app registration, different OS user).
OPENSUBTITLES_API_KEY_FALLBACK=
OPENSUBTITLES_USER_AGENT=SubtitleHub v1.0
# TVMaze enrichment uses public API endpoints; no TVMaze key is required.
