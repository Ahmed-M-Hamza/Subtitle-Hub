{
  "name": "subtitels-hamza",
  "version": "1.0.0",
  "description": "Subtitle Hub — Netlify static + functions deployment",
  "type": "module",
  "main": "netlify/functions/health.js",
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "dev": "npx netlify dev",
    "start": "echo \"Production deploy does not use npm start. Use npm run dev locally.\"",
    "build": "node scripts/generate-launch-seo.mjs",
    "serve:static": "npx serve public",
    "test": "node --test tests/*.test.mjs",
    "regression": "npm test && npm run smoke",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "smoke": "node tests/smoke.mjs",
    "smoke:local": "BASE_URL=http://localhost:8888 node tests/smoke.mjs",
    "smoke:diag": "SMOKE_DIAGNOSTICS=1 node tests/smoke.mjs",
    "smoke:parity": "node tests/subtitles-diagnostics-parity-smoke.mjs"
  },
  "dependencies": {
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "serve": "^14.2.6"
  }
}
